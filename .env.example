# Solana RPC endpoint
# Example: https://api.mainnet-beta.solana.com
SOLANA_RPC_URL=

# Absolute path to local wallet keypair JSON
# Example: /home/username/.config/shield-lite/shield-mainnet.json
SOLANA_KEYPAIR_PATH=

# Jupiter API key
JUPITER_API_KEY=

# Swap execution mode: false = dry-run, true = real swaps
ENABLE_REAL_SWAP=false
